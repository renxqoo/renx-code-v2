{
  "name": "renx-code",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm exec eslint . --ext .ts,.tsx",
    "lint:fix": "pnpm exec eslint . --ext .ts,.tsx --fix",
    "format": "pnpm exec prettier --write \"**/*.{ts,tsx,json,md,yml,yaml,cjs}\"",
    "format:check": "pnpm exec prettier --check \"**/*.{ts,tsx,json,md,yml,yaml,cjs}\"",
    "test": "pnpm --filter @renx-code/core test && pnpm --filter @renxqoo/renx-code test:run",
    "test:coverage": "pnpm --filter @renx-code/core test:coverage && pnpm --filter @renxqoo/renx-code test:run",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "ci:check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@types/strip-ansi": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84"
  },
  "workspaces": [
    "packages/*"
  ]
}
