{
  "name": "@renx-code/server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm --filter @renx-code/core build && tsc -p tsconfig.build.json",
    "typecheck": "pnpm --filter @renx-code/core build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @renx-code/core build && vitest run --config vitest.config.ts",
    "test:coverage": "pnpm --filter @renx-code/core build && vitest run --config vitest.config.ts --coverage",
    "dev": "pnpm --filter @renx-code/core build && tsx src/index.ts"
  },
  "dependencies": {
    "@renx-code/core": "workspace:*"
  }
}
