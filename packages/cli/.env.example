# Agent 完全访问权限配置
# 设置为 1、true、yes 或 on 启用完全访问模式
AGENT_FULL_ACCESS=1

# 会话 ID（可选）
# 用于将多次运行关联到同一个会话，便于排查与追踪
# AGENT_CONVERSATION_ID=opentui-1773897054941

# =========================
# 以下为常用配置示例（按需启用）
# 去掉前面的 # 即可生效
# =========================

# 运行环境标识：development / test / production
# NODE_ENV=development

# 日志级别：debug / info / warn / error
# LOG_LEVEL=debug

# 接口基础地址（后端服务入口）
# API_BASE_URL=http://localhost:3000

# 请求超时时间（毫秒）
# REQUEST_TIMEOUT_MS=15000

# 是否启用调试输出（true/false）
# DEBUG_MODE=true

# 代理地址（网络受限场景）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 不走代理地址列表（逗号分隔）
# NO_PROXY=localhost,127.0.0.1,.internal.local

# 功能开关示例（true/false）
# FEATURE_X_ENABLED=false
