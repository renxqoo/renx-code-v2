{
  "name": "@renxqoo/renx-code",
  "private": true,
  "version": "0.0.18",
  "type": "module",
  "main": "./bin/launcher.cjs",
  "bin": {
    "renx": "./bin/renx.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm --filter @renx-code/core build && node -e \"process.exit(0)\"",
    "dev": "node ./bin/renx.cjs",
    "postinstall": "node ./scripts/install-ripgrep.mjs",
    "test:run:bun": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:run:vitest": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:run": "pnpm run test:run:vitest",
    "typecheck": "pnpm --filter @renx-code/core build && tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "@renx-code/core": "workspace:*",
    "marked": "^15.0.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
