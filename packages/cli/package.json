{
  "name": "@renxqoo/renx-code",
  "private": false,
  "version": "0.0.70",
  "description": "Renx Code terminal AI coding assistant",
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "bin": {
    "renx": "./bin/renx.cjs"
  },
  "exports": {
    ".": {
      "import": "./src/index.tsx",
      "types": "./src/index.tsx"
    }
  },
  "scripts": {
    "build": "pnpm --filter @renx-code/core build && tsc -p tsconfig.build.json",
    "dev": "pnpm --filter @renx-code/core build && bun run src/index.tsx",
    "postinstall": "node ./scripts/install-ripgrep.mjs",
    "release:preflight": "bun ./scripts/release.mjs preflight",
    "release:prepare": "bun ./scripts/prepare-release.mjs",
    "release:pack": "bun ./scripts/release.mjs pack",
    "release:smoke": "node ./scripts/smoke-install.mjs",
    "release:publish": "bun ./scripts/release.mjs publish",
    "test:run:bun": "bun test --no-cache --preload ./test/setup-dom.ts src/context-usage-regressions.test.ts src/components src/files src/hooks src/runtime/cli-args.test.ts src/runtime/clipboard.test.ts src/runtime/terminal-theme.test.ts src/ui",
    "test:run:vitest": "vitest run src/agent/runtime src/commands/slash-commands.test.ts src/runtime/exit.test.ts src/runtime/runtime-support.test.ts",
    "test:run": "pnpm --filter @renx-code/core build && pnpm run test:run:bun && pnpm run test:run:vitest",
    "typecheck": "pnpm --filter @renx-code/core build && tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "renx",
    "renx-code",
    "cli",
    "terminal",
    "ai",
    "coding-assistant",
    "developer-tools",
    "opentui"
  ],
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "@renx-code/core": "workspace:*",
    "marked": "^15.0.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
