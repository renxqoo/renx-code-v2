{
  "name": "@renx-code/weixin-agent",
  "version": "1.0.0",
  "description": "Standalone WeChat (Weixin) agent — long-running process that connects via QR login and auto-replies to messages",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "weixin-agent": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --import tsx src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20"
  }
}
